@page "/sounds"
@implements IDisposable
@inject ApiClient Api
@inject UiState Ui

<PageTitle>Scene Maker — Sounds</PageTitle>

<h2 class="rune">Soundboard</h2>

@if (_boards is null)
{
    <p class="empty-note">Uncorking the sound vials…</p>
}
else if (_boards.Count == 0)
{
    <p class="empty-note">No soundboards found — is Kenku FM running with Remote enabled?</p>
}
else
{
    @foreach (var board in _boards)
    {
        <p class="kgroup-title">@board.Title</p>
        <div class="sound-grid">
            @foreach (var sound in board.Items)
            {
                var playing = _playingIds.Contains(sound.Id);
                <button class="krow @(playing ? "playing" : "")" @onclick="() => Tap(sound, playing)">
                    <span class="krow-ico">@(playing ? "⏹" : "🔊")</span>
                    <span class="krow-title">@sound.Title</span>
                </button>
            }
        </div>
    }
    <p class="hint" style="margin-top:1rem">Tap to fire a sound; tap again to stop it while it plays.</p>
}

@code {
    private List<KenkuGroup>? _boards;
    private HashSet<string> _playingIds = [];
    private Timer? _timer;

    protected override async Task OnInitializedAsync()
    {
        _boards = await Api.GetSoundboardsAsync();
        await PollAsync();
        _timer = new Timer(_ => _ = InvokeAsync(PollAsync), null, 2000, 2000);
    }

    private async Task PollAsync()
    {
        _playingIds = await Api.GetPlayingSoundIdsAsync();
        StateHasChanged();
    }

    private async Task Tap(KenkuItem sound, bool playing)
    {
        var path = playing ? "sfx/stop" : "sfx/play";
        if (await Api.CommandAsync($"{path}?id={Uri.EscapeDataString(sound.Id)}"))
        {
            if (playing) _playingIds.Remove(sound.Id);
            else _playingIds.Add(sound.Id);
        }
    }

    public void Dispose() => _timer?.Dispose();
}
